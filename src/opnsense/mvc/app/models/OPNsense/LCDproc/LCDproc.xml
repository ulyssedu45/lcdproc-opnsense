<model>
    <mount>//OPNsense/lcdproc</mount>
    <description>LCDproc LCD display management</description>
    <version>1.0.0</version>
    <items>
        <!-- General Settings -->
        <general>
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>
            <loglevel type="OptionField">
                <Default>v2</Default>
                <Required>Y</Required>
                <OptionValues>
                    <m1>Disabled</m1>
                    <v0>Critical Errors</v0>
                    <v1>Errors</v1>
                    <v2>Warnings (Default)</v2>
                    <v3>Major Events</v3>
                    <v4>Minor Events</v4>
                    <v5>All messages plus debugging information</v5>
                </OptionValues>
            </loglevel>
            <comport type="OptionField">
                <Default>dev_cuaU0</Default>
                <Required>Y</Required>
                <OptionValues>
                    <none>none</none>
                    <dev_cua0>Serial COM port 1 (/dev/cua0)</dev_cua0>
                    <dev_cua1>Serial COM port 2 (/dev/cua1)</dev_cua1>
                    <dev_cuau0>Serial COM port 1 alternate (/dev/cuau0)</dev_cuau0>
                    <dev_cuau1>Serial COM port 2 alternate (/dev/cuau1)</dev_cuau1>
                    <dev_cuaU0>USB COM port 1 (/dev/cuaU0)</dev_cuaU0>
                    <dev_cuaU1>USB COM port 2 (/dev/cuaU1)</dev_cuaU1>
                    <dev_lpt0>Parallel port 1 (/dev/lpt0)</dev_lpt0>
                    <dev_ttyU0>USB COM port 1 tty (/dev/ttyU0)</dev_ttyU0>
                    <dev_ttyU1>USB COM port 2 tty (/dev/ttyU1)</dev_ttyU1>
                    <dev_ttyU2>USB COM port 3 tty (/dev/ttyU2)</dev_ttyU2>
                    <dev_ttyU3>USB COM port 4 tty (/dev/ttyU3)</dev_ttyU3>
                    <dev_ugen0_2>USB COM port 1 alternate (/dev/ugen0.2)</dev_ugen0_2>
                    <dev_ugen1_2>USB COM port 2 alternate (/dev/ugen1.2)</dev_ugen1_2>
                    <dev_ugen1_3>USB COM port 3 alternate (/dev/ugen1.3)</dev_ugen1_3>
                    <dev_ugen2_2>USB COM port 4 alternate (/dev/ugen2.2)</dev_ugen2_2>
                </OptionValues>
            </comport>
            <size type="OptionField">
                <Default>s16x2</Default>
                <Required>Y</Required>
                <OptionValues>
                    <s12x1>1 rows 12 columns</s12x1>
                    <s12x2>2 rows 12 columns</s12x2>
                    <s12x4>4 rows 12 columns</s12x4>
                    <s16x1>1 row 16 columns</s16x1>
                    <s16x2>2 rows 16 columns</s16x2>
                    <s16x4>4 rows 16 columns</s16x4>
                    <s20x1>1 row 20 columns</s20x1>
                    <s20x2>2 rows 20 columns</s20x2>
                    <s20x4>4 rows 20 columns</s20x4>
                    <s40x2>2 rows 40 columns</s40x2>
                </OptionValues>
            </size>
            <driver type="OptionField">
                <Default>pyramid</Default>
                <Required>Y</Required>
                <OptionValues>
                    <bayrad>bayrad</bayrad>
                    <CFontz>CrystalFontz</CFontz>
                    <CFontzPacket>CrystalFontz Packet</CFontzPacket>
                    <curses>curses</curses>
                    <CwLnx>CwLnx</CwLnx>
                    <ea65>ea65</ea65>
                    <EyeboxOne>EyeboxOne</EyeboxOne>
                    <glcd>GLCD</glcd>
                    <glk>glk</glk>
                    <hd44780>HD44780 and compatible</hd44780>
                    <icp_a106>icp_a106</icp_a106>
                    <IOWarrior>IOWarrior</IOWarrior>
                    <lb216>lb216</lb216>
                    <lcdm001>lcdm001</lcdm001>
                    <lcterm>lcterm</lcterm>
                    <MD8800>MD8800</MD8800>
                    <ms6931>ms6931</ms6931>
                    <mtc_s16209x>mtc_s16209x</mtc_s16209x>
                    <MtxOrb>Matrix Orbital and Compatible</MtxOrb>
                    <NoritakeVFD>NoritakeVFD</NoritakeVFD>
                    <picolcd>picolcd</picolcd>
                    <pyramid>pyramid</pyramid>
                    <rawserial>rawserial</rawserial>
                    <sdeclcd>Watchguard Firebox with SDEC</sdeclcd>
                    <sed1330>sed1330</sed1330>
                    <sed1520>sed1520</sed1520>
                    <serialPOS>serialPOS</serialPOS>
                    <serialVFD>serialVFD</serialVFD>
                    <shuttleVFD>shuttleVFD</shuttleVFD>
                    <sli>sli</sli>
                    <stv5730>stv5730</stv5730>
                    <SureElec>Sure Electronics</SureElec>
                    <t6963>t6963</t6963>
                    <text>text</text>
                    <tyan>tyan</tyan>
                    <vlsys_m428>VLSys M428</vlsys_m428>
                </OptionValues>
            </driver>
            <connection_type type="OptionField">
                <Default>lcd2usb</Default>
                <Required>N</Required>
                <BlankDesc>Not applicable (non-HD44780)</BlankDesc>
                <OptionValues>
                    <c4bit>4bit wiring to parallel port</c4bit>
                    <c8bit>8bit wiring to parallel port (lcdtime)</c8bit>
                    <winamp>8bit wiring winamp style to parallel port</winamp>
                    <serialLpt>Serial LPT wiring</serialLpt>
                    <picanlcd>PIC-an-LCD serial device</picanlcd>
                    <lcdserializer>LCD serializer</lcdserializer>
                    <los_panel>LCD on serial panel device</los_panel>
                    <vdr_lcd>VDR LCD serial device</vdr_lcd>
                    <vdr_wakeup>VDR-Wakeup module</vdr_wakeup>
                    <pertelian>Pertelian X2040 LCD</pertelian>
                    <bwctusb>BWCT USB device</bwctusb>
                    <lcd2usb>Till Harbaum's LCD2USB</lcd2usb>
                    <usbtiny>Dick Streefland's USBtiny</usbtiny>
                    <lis2>LIS2 from VLSystem</lis2>
                    <mplay>MPlay Blast from VLSystem</mplay>
                    <ftdi>LCD connected to FTDI 2232D USB chip</ftdi>
                    <usblcd>USBLCD adapter from Adams IT Services</usblcd>
                    <i2c>LCD driven by PCF8574/PCA9554 connected via i2c</i2c>
                    <ezio>Portwell EZIO-100 and EZIO-300</ezio>
                </OptionValues>
            </connection_type>
            <mtxorb_type type="OptionField">
                <Default>lcd</Default>
                <Required>N</Required>
                <BlankDesc>Not applicable (non-Matrix Orbital)</BlankDesc>
                <OptionValues>
                    <lcd>LCD (default)</lcd>
                    <lkd>LKD</lkd>
                    <vfd>VFD</vfd>
                    <vkd>VKD</vkd>
                </OptionValues>
            </mtxorb_type>
            <mtxorb_adjustable_backlight type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </mtxorb_adjustable_backlight>
            <mtxorb_backlight_color type="OptionField">
                <Default></Default>
                <Required>N</Required>
                <BlankDesc>Default</BlankDesc>
                <OptionValues>
                    <white>White</white>
                    <gray>Gray</gray>
                    <gray_alt>Gray Alt</gray_alt>
                    <red>Red</red>
                    <green>Green</green>
                    <blue>Blue</blue>
                    <cyan>Cyan</cyan>
                    <yellow>Yellow</yellow>
                    <yellow_alt>Yellow Alt</yellow_alt>
                    <magenta>Magenta</magenta>
                    <magenta_alt>Magenta Alt</magenta_alt>
                    <purple>Purple</purple>
                </OptionValues>
            </mtxorb_backlight_color>
            <port_speed type="OptionField">
                <Default>b0</Default>
                <Required>Y</Required>
                <OptionValues>
                    <b0>Default</b0>
                    <b1200>1200 bps</b1200>
                    <b2400>2400 bps</b2400>
                    <b9600>9600 bps</b9600>
                    <b19200>19200 bps</b19200>
                    <b57600>57600 bps</b57600>
                    <b115200>115200 bps</b115200>
                </OptionValues>
            </port_speed>
            <refresh_frequency type="OptionField">
                <Default>r5</Default>
                <Required>Y</Required>
                <OptionValues>
                    <r1>1 second</r1>
                    <r2>2 seconds</r2>
                    <r3>3 seconds</r3>
                    <r5>5 seconds</r5>
                    <r10>10 seconds</r10>
                    <r15>15 seconds</r15>
                </OptionValues>
            </refresh_frequency>
            <outputleds type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </outputleds>
            <controlmenu type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </controlmenu>
            <brightness type="OptionField">
                <Default>m1</Default>
                <Required>Y</Required>
                <OptionValues>
                    <m1>Default</m1>
                    <p0>0%</p0>
                    <p10>10%</p10>
                    <p20>20%</p20>
                    <p30>30%</p30>
                    <p40>40%</p40>
                    <p50>50%</p50>
                    <p60>60%</p60>
                    <p70>70%</p70>
                    <p80>80%</p80>
                    <p90>90%</p90>
                    <p100>100%</p100>
                </OptionValues>
            </brightness>
            <contrast type="OptionField">
                <Default>m1</Default>
                <Required>Y</Required>
                <OptionValues>
                    <m1>Default</m1>
                    <p0>0%</p0>
                    <p10>10%</p10>
                    <p20>20%</p20>
                    <p30>30%</p30>
                    <p40>40%</p40>
                    <p50>50%</p50>
                    <p60>60%</p60>
                    <p70>70%</p70>
                    <p80>80%</p80>
                    <p90>90%</p90>
                    <p100>100%</p100>
                </OptionValues>
            </contrast>
            <backlight type="OptionField">
                <Default>default</Default>
                <Required>Y</Required>
                <OptionValues>
                    <default>Default</default>
                    <on>On</on>
                    <off>Off</off>
                </OptionValues>
            </backlight>
            <offbrightness type="OptionField">
                <Default>m1</Default>
                <Required>Y</Required>
                <OptionValues>
                    <m1>Default</m1>
                    <p0>0%</p0>
                    <p10>10%</p10>
                    <p20>20%</p20>
                    <p30>30%</p30>
                    <p40>40%</p40>
                    <p50>50%</p50>
                    <p60>60%</p60>
                    <p70>70%</p70>
                    <p80>80%</p80>
                    <p90>90%</p90>
                    <p100>100%</p100>
                </OptionValues>
            </offbrightness>
        </general>
        <!-- Screen Configuration -->
        <screens>
            <scr_version type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_version>
            <scr_time type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_time>
            <scr_uptime type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_uptime>
            <scr_hostname type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_hostname>
            <scr_system type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_system>
            <scr_disk type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_disk>
            <scr_load type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_load>
            <scr_states type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_states>
            <scr_carp type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_carp>
            <scr_ipsec type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_ipsec>
            <scr_interfaces type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_interfaces>
            <scr_gwsum type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_gwsum>
            <scr_gwstatus type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_gwstatus>
            <scr_mbuf type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_mbuf>
            <scr_packages type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_packages>
            <scr_cpufrequency type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_cpufrequency>
            <scr_ntp type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_ntp>
            <scr_cputemperature type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_cputemperature>
            <scr_cputemperature_unit type="OptionField">
                <Default>c</Default>
                <Required>Y</Required>
                <OptionValues>
                    <c>Celsius</c>
                    <f>Fahrenheit</f>
                </OptionValues>
            </scr_cputemperature_unit>
            <scr_traffic type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_traffic>
            <scr_traffic_interface type="InterfaceField">
                <Required>N</Required>
                <AllowDynamic>1</AllowDynamic>
                <Filters>
                    <enable>/^1$/</enable>
                </Filters>
            </scr_traffic_interface>
            <scr_top_interfaces_by_bps type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_top_interfaces_by_bps>
            <scr_top_interfaces_by_total_bytes type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_top_interfaces_by_total_bytes>
            <scr_top_interfaces_by_bytes_today type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_top_interfaces_by_bytes_today>
            <scr_interfaces_link type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_interfaces_link>
            <scr_traffic_by_address type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_traffic_by_address>
            <scr_traffic_by_address_if type="InterfaceField">
                <Required>N</Required>
                <AllowDynamic>1</AllowDynamic>
                <Filters>
                    <enable>/^1$/</enable>
                </Filters>
            </scr_traffic_by_address_if>
            <scr_traffic_by_address_sort type="OptionField">
                <Default>in</Default>
                <Required>Y</Required>
                <OptionValues>
                    <in>Bandwidth In</in>
                    <out>Bandwidth Out</out>
                </OptionValues>
            </scr_traffic_by_address_sort>
            <scr_traffic_by_address_filter type="OptionField">
                <Default>local</Default>
                <Required>Y</Required>
                <OptionValues>
                    <local>Local</local>
                    <remote>Remote</remote>
                    <all>All</all>
                </OptionValues>
            </scr_traffic_by_address_filter>
            <scr_traffic_by_address_hostipformat type="OptionField">
                <Default>descr</Default>
                <Required>Y</Required>
                <OptionValues>
                    <ip>IP Address</ip>
                    <hostname>Host Name</hostname>
                    <descr>Description</descr>
                    <fqdn>FQDN</fqdn>
                </OptionValues>
            </scr_traffic_by_address_hostipformat>
            <scr_apcupsd type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_apcupsd>
            <scr_nutups type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </scr_nutups>
        </screens>
    </items>
</model>
